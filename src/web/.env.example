# ---------------------------------------------------------------------------
# BeeEye web — configuration template. Copy to .env for local development.
# .env is git-ignored; never commit real values. The SPA public-client id is not
# itself a secret, but keep tenant-specific configuration out of version control.
# ---------------------------------------------------------------------------

# --- API host ---------------------------------------------------------------
# Leave blank in dev to use the Vite proxy to the .NET host (http://localhost:5080).
VITE_API_BASE_URL=

# --- Authentication mode ----------------------------------------------------
# 'entra' = real Entra sign-in via MSAL (bearer on every call, anonymous users gated).
# 'local' = anonymous: no bearer, no gate — mirrors the backend LocalDev posture and is
#           the zero-config developer default.
# Defaults to 'local' when VITE_AAD_CLIENT_ID is absent. A build intended for deployment
# MUST set VITE_AUTH_MODE=entra and supply all three VITE_AAD_* values below, or the
# production `vite build` fails fast rather than shipping an accidentally-anonymous app.
VITE_AUTH_MODE=local

# --- Entra (required only when VITE_AUTH_MODE=entra) -------------------------
# SPA public client (PKCE) application id.
VITE_AAD_CLIENT_ID=
# e.g. https://login.microsoftonline.com/{tenantId}/v2.0
# MUST equal the backend's Auth:Authority.
VITE_AAD_AUTHORITY=
# The API scope to request for the access token, e.g. api://{api-app-id}/access_as_user.
VITE_AAD_API_SCOPE=
# Optional; defaults to the app origin (window.location.origin).
VITE_AAD_REDIRECT_URI=
