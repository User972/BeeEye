{
  "name": "@beeeye/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BeeEye platform web application (React + TypeScript + Vite).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:update": "playwright test --grep @visual --update-snapshots",
    "lint": "eslint .",
    "gen:api": "openapi-typescript ./openapi/openapi.json -o ./src/lib/api/schema.d.ts"
  },
  "dependencies": {
    "@azure/msal-browser": "5.17.1",
    "@azure/msal-react": "5.5.3",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-router": "^1.95.1",
    "@tanstack/react-table": "^8.20.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.5.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.0.5",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  }
}
