# ---------------------------------------------------------------------------
# Meridian BI — example configuration for a production backend.
# Copy to .env and fill in. NEVER commit real secrets. The POC front-end
# runs fully without any of these (deterministic insight engine + embedded data).
# ---------------------------------------------------------------------------

# --- AI provider (choose one; leave blank to force deterministic mode) ------
AI_PROVIDER=azure_openai            # azure_openai | openai | none
AZURE_OPENAI_ENDPOINT=              # e.g. https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=              # store in Azure Key Vault in production
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-06-01
AI_MAX_TOKENS=900
AI_TEMPERATURE=0.2

# --- Data sources -----------------------------------------------------------
SALES_DATA_PATH=./data/sales.json
INVENTORY_DATA_PATH=./data/inventory.json
# Future: Oracle Fusion connection (not used in the POC)
ORACLE_FUSION_BASE_URL=
ORACLE_FUSION_CLIENT_ID=
ORACLE_FUSION_CLIENT_SECRET=

# --- Analysis defaults (mirror POC Settings) --------------------------------
INVENTORY_ANALYSIS_DATE=2026-06-30
AGING_BANDS_DAYS=30,60,90,120
RISK_BANDS=34,59,79
RISK_WEIGHTS_COVER=30
RISK_WEIGHTS_AGING=25
RISK_WEIGHTS_DEMAND=20
RISK_WEIGHTS_HOLDING=15
RISK_WEIGHTS_LEAD=10
TRAILING_DEMAND_MONTHS=3
FORECAST_HOLDOUT_MONTHS=6
FORECAST_HORIZON_MONTHS=6
FORECAST_CONFIDENCE=80

# --- Platform (production only) ---------------------------------------------
AZURE_KEY_VAULT_URI=
APPLICATIONINSIGHTS_CONNECTION_STRING=
ENTRA_TENANT_ID=
ENVIRONMENT=dev                     # dev | test | prod
