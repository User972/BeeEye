# ---------------------------------------------------------------------------
# BeeEye platform — configuration template. Copy to .env for local development.
# NEVER commit real secrets. In deployed environments, secrets come from Azure
# Key Vault via managed identity — not from environment files.
# ---------------------------------------------------------------------------

ENVIRONMENT=dev                    # dev | test | uat | prod

# --- API host ---------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:5080

# --- Web (Vite) -------------------------------------------------------------
# Leave blank in dev to use the Vite proxy to the API.
VITE_API_BASE_URL=

# --- PostgreSQL (local docker-compose) --------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=beeeye
POSTGRES_USER=beeeye
# Local dev only; production uses Entra ID / managed identity, no password.
POSTGRES_PASSWORD=beeeye_local_dev_only

# --- Azure (deployed environments; prefer managed identity) -----------------
AZURE_KEY_VAULT_NAME=
APPLICATIONINSIGHTS_CONNECTION_STRING=
ENTRA_TENANT_ID=
ENTRA_API_CLIENT_ID=

# --- Oracle Fusion (read-only system of record; not connected in the scaffold)
ORACLE_FUSION_BASE_URL=
# Credentials belong in Key Vault, never here.

# --- Generative AI (provider-neutral; all optional, disabled by default) ----
AI_ENABLED=false                   # master switch for external AI providers
AI_DEFAULT_PROVIDER=               # azure_openai | openai | anthropic | gemini | ollama
# Model aliases map to providers via admin policy, not code:
#   executive-summary | analyst-explanation | recommendation-narrative | data-quality-assistant
